@startuml secuencia-crear-reserva
actor Cliente
participant "ReservaService" as RS
participant "CanchaRepository" as CR
participant "EstrategiaTarifa" as ET
participant "ReservaRepository" as RR
participant "NotificacionService" as NS

Cliente -> RS: crearReserva(clienteId, canchaId, franja)
activate RS

RS -> CR: buscarCancha(canchaId)
activate CR
CR --> RS: cancha
deactivate CR

RS -> CR: estaDisponible(cancha, franja)
activate CR
CR --> RS: disponible = true
deactivate CR

alt franja en horario de baja demanda
  RS -> ET: calcular(cancha, franja) [TarifaPromocional]
else horario normal / pico
  RS -> ET: calcular(cancha, franja) [TarifaEstandar u HorarioPico]
end
activate ET
ET --> RS: precioTotal
deactivate ET

RS -> RR: guardar(reserva)
activate RR
RR --> RS: reserva confirmada
deactivate RR

RS -> NS: notificar(cliente, reserva)
activate NS
NS --> RS: ok
deactivate NS

RS --> Cliente: reserva confirmada
deactivate RS
@enduml
