@startuml secuencia-cancelar-reserva
actor Cliente
participant "ReservaService" as RS
participant "ReservaRepository" as RR
participant "NotificacionService" as NS

Cliente -> RS: cancelarReserva(reservaId)
activate RS

RS -> RR: buscarPorId(reservaId)
activate RR
RR --> RS: reserva
deactivate RR

RS -> RS: verificarPoliticaCancelacion(reserva)

alt cumple política (antelación suficiente)
  RS -> RS: reserva.cancelar()
  RS -> RR: guardar(reserva)
  activate RR
  RR --> RS: ok
  deactivate RR
  RS -> NS: notificar(cliente, reserva cancelada)
  activate NS
  NS --> RS: ok
  deactivate NS
  RS --> Cliente: cancelación confirmada
else no cumple política
  RS --> Cliente: error: fuera de plazo de cancelación
end

deactivate RS
@enduml
